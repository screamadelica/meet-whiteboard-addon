{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,  
  "rewrites": [
    { "source": "/side-panel.html", "destination": "/side-panel.html" },
    { "source": "/main-stage.html", "destination": "/main-stage.html" },
    { "source": "/mobile.html", "destination": "/mobile.html" },
    { "source": "/api/:name", "destination": "/api/:name.js" }
  ],
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ]  
}
